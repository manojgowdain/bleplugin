# Ignore native folders so EAS Build uses app.json config
android/
ios/
.expo/

# Ignore local node_modules cache
node_modules/

# Ignore debug build artifacts
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore environment files
.env
.env.local
.env.development
.env.production
.env.test

# Ignore Expo's local settings
.expo/
.expo-shared/

# Ignore build outputs
dist/
build/
web-build/

# Ignore macOS system files
.DS_Store
